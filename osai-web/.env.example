# ─── OSAI Frontend Environment Variables ───────────────────────────────────
# Copy this file to `.env.local` for local development.
# In Vercel, set these in Project Settings → Environment Variables.

# Backend API URL — where the Next.js app sends API requests.
# Local:   http://localhost:8000
# Staging: https://api-staging.osai.dev
# Prod:    https://api.osai.dev
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# (Optional) Default org ID for demo/development — skips the login flow.
# Remove in production.
NEXT_PUBLIC_DEFAULT_ORG_ID=demo-org

# (Optional) Enable demo mode — shows demo data badges, suggestion prompts.
# Set to "true" for demo deploys, omit or "false" for production.
NEXT_PUBLIC_DEMO_MODE=true
