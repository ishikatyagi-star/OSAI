# ─── OSAI Frontend Environment Variables ───────────────────────────────────
# Copy this file to `.env.local` for local development.
# In Vercel, set these in Project Settings → Environment Variables.

# Backend API URL — where the Next.js app sends API requests.
# Local:   http://localhost:8000
# Staging: https://api-staging.osai.dev
# Prod:    https://api.osai.dev
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional demo-only build flag. Use exactly "1" for the pitch/demo deployment;
# omit it in production. Runtime demo sessions can also opt in via localStorage.
NEXT_PUBLIC_OSAI_DEMO=1
