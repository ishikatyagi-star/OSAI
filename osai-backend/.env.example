OSAI_ENV=local
# Host-run backend -> Compose's loopback port. Containers override this to
# postgres:5432 in docker-compose.yml.
OSAI_DATABASE_URL=postgresql+psycopg://osai:osai@localhost:5433/osai
OSAI_REDIS_URL=redis://localhost:6379/0
# The application, not Uvicorn, owns proxy trust. Use direct unless deployment
# documentation explicitly names another mode. trusted_chain also requires
# explicit, non-/0 OSAI_RATE_LIMIT_TRUSTED_PROXY_CIDRS.
OSAI_RATE_LIMIT_FORWARDED_FOR_MODE=direct
OSAI_RATE_LIMIT_TRUSTED_PROXY_CIDRS=
OSAI_RATE_LIMIT_MEMORY_MAX_KEYS=10000
OSAI_RATE_LIMIT_REDIS_MAX_KEYS=10000
# Group IPv6 callers by allocation before hashing (valid: 32-128); 128 restores
# per-address identities.
OSAI_RATE_LIMIT_IPV6_PREFIX_LENGTH=64
OSAI_QDRANT_URL=http://localhost:6333
OSAI_QDRANT_API_KEY=
OSAI_QDRANT_COLLECTION=osai_chunks
OSAI_EMBEDDING_DIMENSION=768
OSAI_DEFAULT_ORG_ID=demo-org
OSAI_ALLOWED_ORIGINS=http://localhost:3000
# Required when OSAI_ENV is not local. Generate a fresh value with
# `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
# OSAI_JWT_SECRET=
# Public URLs for the OAuth auto-ingest callback (set on Render in prod)
OSAI_PUBLIC_BASE_URL=
OSAI_FRONTEND_URL=

# Google user sign-in (required for the production login path)
OSAI_GOOGLE_OAUTH_CLIENT_ID=
OSAI_GOOGLE_OAUTH_CLIENT_SECRET=
OSAI_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Gemini — embeddings, and fallback text generation when OSAI_LLM_API_KEY is unset.
# Required when OSAI_ENV is not local.
OSAI_GEMINI_API_KEY=

# Optional alternative embedding provider. When set, Voyage takes precedence
# over Gemini. Keep OSAI_EMBEDDING_DIMENSION aligned with the chosen model.
OSAI_VOYAGE_API_KEY=
OSAI_VOYAGE_MODEL=voyage-3.5-lite
OSAI_VOYAGE_BASE_URL=https://api.voyageai.com/v1

# LLM text generation — any OpenAI-compatible provider (Groq, OpenRouter,
# GitHub Models, Cerebras, Mistral). When set, preferred over Gemini for text-gen.
OSAI_LLM_API_KEY=
OSAI_LLM_BASE_URL=https://api.groq.com/openai/v1
OSAI_LLM_MODEL=llama-3.3-70b-versatile

# Optional Hermes execution sidecar. In non-local environments the token is
# required whenever the URL is set; use the same value as SIDECAR_AUTH_TOKEN.
OSAI_HERMES_SIDECAR_URL=
OSAI_HERMES_SIDECAR_TOKEN=

# Composio — universal tool/integration layer (P2). no_auth tools (web search)
# work immediately; OAuth tools (Gmail, Calendar) need a connected account.
OSAI_COMPOSIO_API_KEY=
OSAI_COMPOSIO_TOOLKITS=composio_search
# Comma-separated exact hosts (or .suffixes) trusted for provider-returned
# temporary downloads. Blank safely disables remote download URLs.
OSAI_COMPOSIO_DOWNLOAD_HOSTS=
# Direct cloud-model tool calling stays off until an administrator explicitly
# permits red-tier cloud processing for the workspace.
OSAI_COMPOSIO_AGENT_ENABLED=false

# Choose one recurring-automation scheduler per deployment. Defaults preserve
# the external GitHub-cron topology; a Celery-beat worker should set cron false
# and beat true. Never enable both against the same database.
OSAI_AUTOMATIONS_CRON_TOKEN=
OSAI_AUTOMATIONS_CRON_ENABLED=true
OSAI_AUTOMATIONS_BEAT_ENABLED=false

# Optional Sentry-compatible error tracking DSN.
OSAI_SENTRY_DSN=

# Optional gbrain CLI integration (not a root Compose service). Set the brain
# data directory only after checking out the submodule and initializing it.
# Init once: cd services/gbrain && bun install && \
#   GBRAIN_HOME=/path/to/brain bun run src/cli.ts init --pglite --no-embedding
# OSAI_GBRAIN_HOME=/tmp/osai-brain
# OSAI_GBRAIN_CLI_DIR=../services/gbrain

# Notion
OSAI_NOTION_API_TOKEN=
OSAI_NOTION_ROOT_PAGE_ID=

# Slack
OSAI_SLACK_BOT_TOKEN=
# Required for /slack/ask: Slack app Basic Information -> Signing Secret.
OSAI_SLACK_SIGNING_SECRET=

# Optional comma-separated exact hostnames for deliberately peered/VPN
# PostgreSQL sources. Never include loopback, metadata, or the app control DB.
OSAI_SQL_SOURCE_HOST_ALLOWLIST=
# Required before storing a SQL source. Comma-separated Fernet keys, newest
# first, allow staged rotation. Generate one without printing any other secret:
# python -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
OSAI_SQL_DSN_ENCRYPTION_KEYS=

# Freshdesk
OSAI_FRESHDESK_DOMAIN=yourcompany.freshdesk.com
OSAI_FRESHDESK_API_KEY=

# Google Drive (service account)
OSAI_GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service_account.json
OSAI_GOOGLE_DRIVE_FOLDER_ID=

# Supermemory memory backbone (optional). Without a key OSAI uses Postgres
# org-memory only. Set OSAI_SUPERMEMORY_URL to a self-hosted instance before
# storing anything above normal tier.
OSAI_SUPERMEMORY_API_KEY=
OSAI_SUPERMEMORY_URL=
