OSAI_ENV=local
OSAI_DATABASE_URL=postgresql+psycopg://osai:osai@localhost:5432/osai
OSAI_QDRANT_URL=http://localhost:6333
OSAI_QDRANT_API_KEY=
OSAI_QDRANT_COLLECTION=osai_chunks
OSAI_EMBEDDING_DIMENSION=768
OSAI_DEFAULT_ORG_ID=demo-org
OSAI_ALLOWED_ORIGINS=http://localhost:3000
# Public URLs for the OAuth auto-ingest callback (set on Render in prod)
OSAI_PUBLIC_BASE_URL=
OSAI_FRONTEND_URL=

# Gemini — embeddings always; also text-gen if no OpenRouter key set
OSAI_GEMINI_API_KEY=

# LLM text generation — any OpenAI-compatible provider (Groq, OpenRouter,
# GitHub Models, Cerebras, Mistral). When set, preferred over Gemini for text-gen.
OSAI_LLM_API_KEY=
OSAI_LLM_BASE_URL=https://api.groq.com/openai/v1
OSAI_LLM_MODEL=llama-3.3-70b-versatile

# Composio — universal tool/integration layer (P2). no_auth tools (web search)
# work immediately; OAuth tools (Gmail, Calendar) need a connected account.
OSAI_COMPOSIO_API_KEY=
OSAI_COMPOSIO_TOOLKITS=composio_search

# gbrain knowledge-graph sidecar (P4). Opt-in: set the brain data dir to enable.
# Init once: cd services/gbrain && bun install && \
#   GBRAIN_HOME=/path/to/brain bun run src/cli.ts init --pglite --no-embedding
# OSAI_GBRAIN_HOME=/tmp/osai-brain
# OSAI_GBRAIN_CLI_DIR=../services/gbrain

# Notion
OSAI_NOTION_API_TOKEN=
OSAI_NOTION_ROOT_PAGE_ID=

# Slack
OSAI_SLACK_BOT_TOKEN=

# Freshdesk
OSAI_FRESHDESK_DOMAIN=yourcompany.freshdesk.com
OSAI_FRESHDESK_API_KEY=

# Google Drive (service account)
OSAI_GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service_account.json
OSAI_GOOGLE_DRIVE_FOLDER_ID=

# Supermemory memory backbone (optional). Without a key OSAI uses Postgres
# org-memory only. Set OSAI_SUPERMEMORY_URL to a self-hosted instance before
# storing anything above normal tier.
OSAI_SUPERMEMORY_API_KEY=
OSAI_SUPERMEMORY_URL=
